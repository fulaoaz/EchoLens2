# EchoLens 2.0 — example env. Copy to .env and fill in secrets.
# This file lives at repo root and is shared by docker-compose.

# === LLM (OpenAI-compatible) ===
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# === Storage paths (defaults are fine for local dev) ===
KUZU_DB_PATH=./data/kuzu_db
DUCKDB_PATH=./data/echolens.duckdb
UPLOAD_DIR=./data/uploads

# === Logging ===
LOG_LEVEL=INFO
