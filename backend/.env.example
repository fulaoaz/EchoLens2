# EchoLens 2.0 backend environment template.
# Copy this file to `.env` and fill in real values.

# --- LLM (OpenAI-compatible) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# --- Storage ---
KUZU_DB_PATH=./data/kuzu_db
DUCKDB_PATH=./data/echolens.duckdb
UPLOAD_DIR=./data/uploads

# --- Runtime ---
LOG_LEVEL=INFO
FLASK_DEBUG=0

# --- CORS ---
# Comma-separated list of allowed origins for /api/*. Leave empty in development
# to permit any origin (default `*`). In production, set to a strict whitelist:
#   ALLOWED_ORIGINS=https://app.echolens.ai,https://staging.echolens.ai
ALLOWED_ORIGINS=
